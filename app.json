{
  "expo": {
    "name": "WarZone Free Fire Tournament",
    "slug": "warzone-free-fire",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo/game_logo.png",
    "userInterfaceStyle": "dark",
    "extra": {
      "eas": {
        "projectId": "9bf33d68-cc48-4456-9873-3cb14d624b77"
      }
    },
    "splash": {
      "image": "./assets/logo/game_logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0e27"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.skwin.tournament"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo/game_logo.png",
        "backgroundColor": "#0a0e27"
      },
      "package": "com.skwin.tournament"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "newArchEnabled": false
          },
          "ios": {
            "newArchEnabled": false
          }
        }
      ],
      "@react-native-community/datetimepicker"
    ]
  }
}
