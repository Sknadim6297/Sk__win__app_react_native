# Copy to backend/.env

# Local MongoDB (default — requires MongoDB running on your PC)
MONGODB_URI=mongodb://127.0.0.1:27017/sk-win

# OR MongoDB Atlas (free cloud — recommended if you don't have MongoDB installed)
# MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/sk-win?retryWrites=true&w=majority

JWT_SECRET=your_super_secret_jwt_key_change_this
PORT=5000
NODE_ENV=development
