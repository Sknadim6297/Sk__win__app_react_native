# Frontend Environment Variables
# Create .env file with these values in backend folder

# Copy to .env in project root — use your PC LAN IP when testing on a physical phone
# Example: EXPO_PUBLIC_API_URL=http://192.168.1.42:5000/api
EXPO_PUBLIC_API_URL=http://localhost:5000/api
EXPO_PUBLIC_APP_NAME=WarZone Free Fire Tournament
